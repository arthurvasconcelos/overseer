# Brewfile.local — machine-specific packages (not committed)
# Copy this file to Brewfile.local and uncomment/add what you need.

# Example: GUI apps only on your personal machine
# cask "spotify"
# cask "discord"

# Example: work-specific tools
# brew "awscli"
# brew "kubectl"

# Example: fonts
# tap "homebrew/cask-fonts"
# cask "font-jetbrains-mono"
